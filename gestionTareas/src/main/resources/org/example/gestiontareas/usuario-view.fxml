       <TextField fx:id="txtNombre" layoutX="80.0" layoutY="45.0" promptText="Nombre" />
       <Button layoutX="31.0" layoutY="138.0" onAction="#anadirUsuario" text="Añadir" />
       <Button layoutX="105.0" layoutY="138.0" onAction="#modificarUsuario" text="Modificar" />
       <Button layoutX="181.0" layoutY="138.0" onAction="#borrarUsuario" text="Borrar" />
       <Button layoutX="237.0" layoutY="138.0" onAction="#cerrarVentana" text="Cerrar" />
   </children>
</AnchorPane>
