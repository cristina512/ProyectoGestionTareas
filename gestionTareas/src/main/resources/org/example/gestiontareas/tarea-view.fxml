<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.debbddajavafx.Presentacion.TareaController">
    <ComboBox fx:id="comboTareas" />
    <TextField fx:id="txtCodigo" promptText="Código" />
    <TextField fx:id="txtNombre" promptText="Nombre" />
    <Button text="Añadir" onAction="#anadirTarea"/>
    <Button text="Modificar" onAction="#modificarTarea"/>
    <Button text="Borrar" onAction="#borrarTarea"/>
    <Button text="Cerrar" onAction="#cerrarVentana"/>
</VBox>

